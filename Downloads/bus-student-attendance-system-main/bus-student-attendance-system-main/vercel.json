{
  "version": 2,
  "buildCommand": "bash build.sh",
  "builds": [
    {
      "src": "bustracking/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    },
    {
      "src": "staticfiles/**",
      "use": "@vercel/static",
      "config": {
        "maxAge": 31536000
      }
    }
  ],
  "routes": [
    {
      "src": "/staticfiles/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "bustracking/wsgi.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11",
    "DEBUG": "False",
    "SECRET_KEY": "@django-insecure-oc=tsiw%r2jpl(9y0_ua_p0)e@q=%@w1-f880pr8@xnoyq2()j",
    "ALLOWED_HOSTS": "*.vercel.app,.vercel.app,localhost,127.0.0.1"
  }
}
